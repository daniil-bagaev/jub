  "scripts": {
    "test": "echo \"Error: no test specified\" && exit 1",
    "start": "(if not exist \".loc\" mkdir \".loc\") && (if not exist \".log\" mkdir \".log\")  &&  (if not exist \"build\" mkdir \"build\")",
    "build": "(gulp >> .log\\temp.log && type .log\\temp.log && type .log\\temp.log >> .log\\gulp.log) && echo.>.log\\temp.log",
    "production": "",
    "deploy": "(gulp git >> .log\\temp.log && type .log\\temp.log && type .log\\temp.log >> .log\\deploy.log) && echo.>.log\\temp.log"
  },
